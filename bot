            f"Подпишись и нажми кнопку проверки ниже 👇",
            parse_mode="Markdown",
            reply_markup=get_sub_keyboard()
        )
        return

    welcome_text = (
        "🔥 **Добро пожаловать в Zifix!**\n\n"
        "📦 Продукт: **Zifix dlc**\n"
        "⚠️ **Внимание! Чит находится на стадии разработки. Многие функции могут быть не оптимизированы!**\n\n"
