@dp.callback_query(F.data.startswith("plat_"))
async def show_tarifs(callback: types.CallbackQuery):
    data_parts = callback.data.split("_")
    method = data_parts[1]      
    platform = data_parts[2]    
    
    buttons = []
    platform_label = "ANDROID" if platform == "android" else "ПК"
    
    if method == "stars":
        for key, val in TARIFS.items():
            button_text = f"⭐ Zifix dlc ({platform_label}) [{val['title']}] — {val['stars']} XTR"
            buttons.append([InlineKeyboardButton(text=button_text, callback_data=f"buy_stars_{key}_{platform}")])
        buttons.append([InlineKeyboardButton(text="🔙 Назад", callback_data="method_stars")])
        await callback.message.edit_text("Выбери тариф для оплаты Звёздами:", reply_markup=InlineKeyboardMarkup(inline_keyboard=buttons))
        
    elif method == "card":
        for key, val in TARIFS.items():
            button_text = f"💳 Zifix dlc ({platform_label}) [{val['title']}] — {val['rub']} ₽"
            buttons.append([InlineKeyboardButton(text=button_text, callback_data=f"pay_card_{key}_{platform}")])
        buttons.append([InlineKeyboardButton(text="🔙 Назад", callback_data="method_card")])
        await callback.message.edit_text("Выбери тариф для перевода на карту:", reply_markup=InlineKeyboardMarkup(inline_keyboard=buttons))


